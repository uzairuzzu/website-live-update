generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String?
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  websites          Website[]
  accounts          Account[]
  sessions          Session[]
  externalProviders ExternalProvider[]
  statusBranding    StatusPageBranding?
  competitors       Competitor[]
  teamMembers       TeamMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Website {
  id                 String              @id @default(cuid())
  userId             String
  name               String
  url                String
  status             String              @default("unknown")
  interval           Int                 @default(5)
  monitorType        String              @default("http")
  consecutiveFailures Int                @default(0)
  sensitivity        String              @default("normal")
  slaTarget          Float               @default(99.9)
  contentHash        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  checks             WebsiteCheck[]
  regionChecks       CheckRegion[]
  incidents          Incident[]
  ssl                SSL?
  domain             DomainInfo?
  notifications      Notification[]
  webhooks           Webhook[]
  maintenances       MaintenanceWindow[]
  keywords           Keyword[]
  tags               WebsiteTag[]
  aggregations       DailyAggregation[]
  baseline           ResponseTimeBaseline?
  performanceBudget  PerformanceBudget?
  certificateLogs    CertificateLog[]
  customScripts      CustomScript[]
  competitors        Competitor[]
}

model WebsiteCheck {
  id                String   @id @default(cuid())
  websiteId         String
  status            String
  statusCode        Int?
  statusMessage     String?
  responseTime      Int?
  errorMessage      String?
  dnsTime           Int?
  tcpTime           Int?
  tlsTime           Int?
  ttfb              Int?
  downloadTime      Int?
  httpVersion       String?
  method            String?
  contentType       String?
  contentLength     Int?
  contentEncoding   String?
  charset           String?
  compression       String?
  server            String?
  poweredBy         String?
  redirectCount     Int?
  redirectChain     String?
  finalUrl          String?
  resolvedIps       String?
  dnsRecords        String?
  requestHeaders    String?
  responseHeaders   String?
  securityHeaders   String?
  cookies           String?
  corsHeaders       String?
  pageTitle         String?
  metaDescription   String?
  metaKeywords      String?
  canonicalUrl      String?
  ogTitle           String?
  ogDescription     String?
  ogImage           String?
  robotsTag         String?
  faviconUrl        String?
  hsts              Boolean?
  xFrameOptions     String?
  contentSecurityPolicy String?
  bodyPreview       String?
  contentHash       String?
  contentChanged    Boolean?
  primaryIp         String?
  ipVersion         String?
  isAnomaly         Boolean?
  anomalyDeviation  Float?
  checkedAt         DateTime @default(now())
  website           Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model CheckRegion {
  id          String   @id @default(cuid())
  websiteId   String
  region      String
  status      String
  statusCode  Int?
  responseTime Int?
  errorMessage String?
  resolvedIp  String?
  checkedAt   DateTime @default(now())
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Incident {
  id          String            @id @default(cuid())
  websiteId   String
  startedAt   DateTime
  endedAt     DateTime?
  duration    Int?
  resolved    Boolean           @default(false)
  severity    String            @default("major")
  rootCause   String?
  impactSummary String?
  website     Website           @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  updates     IncidentUpdate[]
}

model IncidentUpdate {
  id          String   @id @default(cuid())
  incidentId  String
  message     String
  status      String?
  createdAt   DateTime @default(now())
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model SSL {
  id                 String   @id @default(cuid())
  websiteId          String   @unique
  valid              Boolean  @default(true)
  expiryDate         DateTime
  issuer             String?
  subjectName        String?
  validFrom          DateTime?
  validTo            DateTime?
  certificateChain   String?
  issuedBy           String?
  serialNumber       String?
  fingerprint        String?
  fingerprint256     String?
  protocol           String?
  cipherSuite        String?
  keyExchange        String?
  keyAlgorithm       String?
  keySize            Int?
  signatureAlgorithm String?
  san                String?
  dnsNames           String?
  isCA               Boolean?
  selfSigned         Boolean?
  ocspStapled        Boolean?
  crlUrls            String?
  ocspUrls           String?
  weakProtocol       Boolean?  @default(false)
  weakCipher         Boolean?  @default(false)
  checkedAt          DateTime  @default(now())
  website            Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model DomainInfo {
  id            String   @id @default(cuid())
  websiteId     String   @unique
  domain        String?
  registrar     String?
  organization  String?
  country       String?
  creationDate  DateTime?
  expiryDate    DateTime?
  updatedDate   DateTime?
  nameServers   String?
  dnssec        Boolean?
  status        String?
  whoisData     String?
  checkedAt     DateTime @default(now())
  website       Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  websiteId String
  type      String
  message   String?
  severity  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model NotificationSetting {
  id      String @id @default(cuid())
  userId  String
  type    String
  enabled Boolean @default(true)
  value   String?
  @@unique([userId, type])
}

model Webhook {
  id        String   @id @default(cuid())
  websiteId String
  userId    String
  name      String   @default("Default")
  url       String
  type      String   @default("generic")
  events    String   @default("down,up")
  enabled   Boolean  @default(true)
  secret    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]
}

model Tag {
  id        String      @id @default(cuid())
  userId    String
  name      String
  color     String      @default("#6366f1")
  createdAt DateTime    @default(now())
  websites  WebsiteTag[]
  @@unique([userId, name])
}

model WebsiteTag {
  websiteId String
  tagId     String
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([websiteId, tagId])
}

model MaintenanceWindow {
  id        String   @id @default(cuid())
  websiteId String
  startsAt  DateTime
  endsAt    DateTime
  message   String?
  createdAt DateTime @default(now())
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Keyword {
  id          String   @id @default(cuid())
  websiteId   String
  keyword     String
  mode        String   @default("present")
  enabled     Boolean  @default(true)
  lastMatch   Boolean?
  lastChecked DateTime?
  createdAt   DateTime @default(now())
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model ResponseTimeBaseline {
  id              String   @id @default(cuid())
  websiteId       String   @unique
  mean            Float    @default(0)
  stdDeviation    Float    @default(0)
  sampleCount     Int      @default(0)
  lastCalculated  DateTime @default(now())
  website         Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model DailyAggregation {
  id              String   @id @default(cuid())
  websiteId       String
  date            DateTime
  totalChecks     Int      @default(0)
  onlineChecks    Int      @default(0)
  avgResponseTime Float    @default(0)
  minResponseTime Int      @default(0)
  maxResponseTime Int      @default(0)
  uptimePercent   Float    @default(100)
  downtimeSeconds Int      @default(0)
  incidentCount   Int      @default(0)
  website         Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  @@unique([websiteId, date])
}

model ExternalProvider {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  apiKey    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     String
  status      String   @default("pending")
  statusCode  Int?
  response    String?
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  nextRetryAt DateTime?
  createdAt   DateTime @default(now())
  deliveredAt DateTime?
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}

model PerformanceBudget {
  id                    String   @id @default(cuid())
  websiteId             String   @unique
  responseTimeThreshold Int      @default(3000)
  ttfbThreshold         Int      @default(1000)
  downloadTimeThreshold Int      @default(5000)
  uptimeTarget          Float    @default(99.9)
  enabled               Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  website               Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model CertificateLog {
  id              String   @id @default(cuid())
  websiteId       String
  domain          String
  issuerName      String
  serialNumber    String
  notBefore       DateTime
  notAfter        DateTime
  fingerprint     String
  detectedAt      DateTime @default(now())
  alertSent       Boolean  @default(false)
  website         Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model StatusPageBranding {
  id              String   @id @default(cuid())
  userId          String   @unique
  logoUrl         String?
  primaryColor    String   @default("#6366f1")
  backgroundColor String   @default("#ffffff")
  textColor       String   @default("#111827")
  customDomain    String?
  pageTitle       String   @default("Status Page")
  description     String?
  showUptime      Boolean  @default(true)
  showResponseTime Boolean @default(true)
  showSSL         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Competitor {
  id              String   @id @default(cuid())
  userId          String
  name            String
  url             String
  websiteId       String?
  benchmarkUrl    String
  lastChecked     DateTime?
  lastStatus      String?
  lastResponseTime Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  website         Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
}

model CustomScript {
  id          String   @id @default(cuid())
  websiteId   String
  name        String
  code        String
  enabled     Boolean  @default(true)
  lastRunAt   DateTime?
  lastResult  String?
  lastStatus  String?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id         String   @id @default(cuid())
  userId     String
  email      String
  role       String   @default("viewer")
  invitedAt  DateTime @default(now())
  acceptedAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, email])
}
